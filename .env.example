# Agent Permit Office local environment.
#
# Deterministic scan/eval mode requires no model provider keys or live MCP access.

# Live Deep Agent investigation uses OpenRouter.
# Default model: anthropic/claude-sonnet-4.6
# Escalation model: openai/gpt-5.5
OPENROUTER_API_KEY=
# Cost controls default on. Keep prompt cache TTL empty for provider default 5m.
OPENROUTER_PROMPT_CACHE=true
OPENROUTER_PROMPT_CACHE_TTL=
OPENROUTER_RESPONSE_CACHE=true
OPENROUTER_RESPONSE_CACHE_TTL_SECONDS=300
OPENROUTER_TIMEOUT_SECONDS=45
OPENROUTER_MAX_COMPLETION_TOKENS=2400

# Optional local Phoenix tracing for live Deep Agent runs.
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=agent-permit-office

# Optional Phoenix dataset upload for eval rows.
PHOENIX_BASE_URL=http://localhost:6006
